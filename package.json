    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@ton/core": "^0.62.0",
    "@ton/ton": "^16.0.0",
    "@tonconnect/sdk": "^3.3.1",
    "@types/eventsource": "^1.1.15",
    "@types/qrcode": "^1.5.6",
    "dotenv": "^17.2.3",
    "eventsource": "^4.1.0",
