# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Database Configuration
# For development with SQLite: use (file:./dev.db)
# For development with Docker PostgreSQL: use (postgresql://vibe_user:vibe_password@localhost:5432/vibe_kanban)
# For production: use PostgreSQL (postgresql://user:password@host:5432/database)
DATABASE_URL=postgresql://vibe_user:vibe_password@localhost:5432/vibe_kanban

# TON Blockchain Configuration
# Network: testnet or mainnet
TON_NETWORK=testnet
# API key for TON blockchain API access (optional for testnet)
TON_API_KEY=
# URL to your TON Connect manifest JSON for wallet integration
TONCONNECT_MANIFEST_URL=

# Order Book Integration
# Order book API endpoint
ORDER_BOOK_API_URL=https://api.open4dev.com
# Smart contract address for order book (required for production)
ORDER_BOOK_CONTRACT_ADDRESS=

# Open4Dev API Configuration
# API endpoint for Open4Dev services
OPEN4DEV_API_URL=https://api.open4dev.xyz/api/v1
# API key for Open4Dev
OPEN4DEV_API_KEY=b19d7e30f699d1a341a578d61edada9f

# Redis Configuration
# Redis host for caching
REDIS_HOST=localhost
# Redis port
REDIS_PORT=6379
# Redis password (optional, leave empty for no password)
REDIS_PASSWORD=
# Cache TTL in seconds (default: 300 = 5 minutes)
REDIS_TTL=300

# Security & Session Management
# IMPORTANT: Change these secrets in production!
# Generate strong random strings for production use
SESSION_SECRET=change-me-in-production
JWT_SECRET=change-me-in-production

# Trading Limits
# Maximum amount allowed per order (in TON)
MAX_ORDER_AMOUNT=10000
# Minimum amount required per order (in TON)
MIN_ORDER_AMOUNT=0.1

# Rate Limiting
# API rate limit (requests per minute)
API_RATE_LIMIT=60
